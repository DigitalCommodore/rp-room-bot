{
  "name": "rp-room-bot",
  "version": "1.0.0",
  "description": "Discord bot for setting up RP rooms with a modern web UI",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"npx vite client --port 5173\"",
    "build": "cd client && npx vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "discord.js": "^14.16.3",
    "express": "^4.21.1",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "vite": "^6.0.3"
  }
}
